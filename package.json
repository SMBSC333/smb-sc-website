{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "BUILD_TARGET=netlify vite build && node scripts/cleanup-edge.mjs",
    "build:local": "vite build && cp -r public/static dist/",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "hono": "^4.12.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.9.3",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
